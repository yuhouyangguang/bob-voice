SECRET_KEY=replace-with-a-random-secret
JWT_SECRET_KEY=replace-with-another-random-secret

# 首次启动时自动创建管理员。创建后可从环境变量中移除。
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-this-password
BOOTSTRAP_ADMIN_NAME=系统管理员

DASHSCOPE_API_KEY=
DASHSCOPE_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1
FILE_ASR_MODEL=fun-asr
REALTIME_ASR_MODEL=paraformer-realtime-v2

DATABASE_URL=sqlite:////absolute/path/to/bob_voice.db
STORAGE_DIR=/absolute/path/to/storage
MAX_UPLOAD_MB=500
TASK_WORKERS=2

HOST=0.0.0.0
PORT=5000
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:5173
