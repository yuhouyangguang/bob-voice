# ── Bob Voice 部署配置 ──────────────────────────────────────────────
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ── 安全密钥（必填，请生成随机字符串）──────────────────────────────
SECRET_KEY=replace-with-a-random-secret
JWT_SECRET_KEY=replace-with-another-random-secret

# ── 初始管理员（首次启动时自动创建）─────────────────────────────────
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=Admin123!
BOOTSTRAP_ADMIN_NAME=系统管理员

# ── 阿里云 DashScope ASR（必填）──────────────────────────────────
DASHSCOPE_API_KEY=your-dashscope-api-key
ASR_PROVIDER=dashscope
FILE_ASR_MODEL=fun-asr
REALTIME_ASR_MODEL=paraformer-realtime-v2

# ── 服务配置 ─────────────────────────────────────────────────────
APP_PORT=80
MAX_UPLOAD_MB=500
TASK_WORKERS=2
COOKIE_SECURE=false
CORS_ORIGINS=

# ── JWT ─────────────────────────────────────────────────────────
JWT_EXPIRES_HOURS=8
